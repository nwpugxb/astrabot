<?xml version="1.0"?>
<!-- Indoor inspection robot (new stepper/ESP32 chassis).
     REP-103: +X forward, +Y left, +Z up. Origin = ground point between drive wheels.

     >>> ALL DIMENSIONS BELOW ARE PLACEHOLDERS <<<
     Measure the real chassis and update: wheel separation, wheel radius,
     lidar mount (x/y/z), camera mount (x/z + pitch). These feed odometry
     (separation/radius) and sensor extrinsics (lidar/camera), so get them right.
-->
<robot name="indoor_robot">
  <!-- ============ Base ============ -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <box size="0.40 0.35 0.12"/> <!-- TODO: real chassis L x W x H -->
      </geometry>
      <material name="gray"><color rgba="0.55 0.55 0.55 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <box size="0.40 0.35 0.12"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <mass value="10.0"/> <!-- TODO -->
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.15"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ============ Drive wheels ============
       WHEEL_SEPARATION (track) and WHEEL_RADIUS must match ESP32 odometry params. -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0500" length="0.03"/></geometry> <!-- TODO radius -->
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0500" length="0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0500" length="0.03"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0500" length="0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- y = +/- half_track (TODO: real half of wheel separation); z = wheel radius. -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.150 0.0500" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.150 0.0500" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ============ A1 Lidar ============
       frame_id of sllidar must be "laser" (see sensors.launch.py).
       TODO: set real mount x (forward offset) and z (height). -->
  <link name="laser">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.038" length="0.04"/></geometry>
      <material name="darkblue"><color rgba="0.1 0.1 0.4 1"/></material>
    </visual>
  </link>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0.10 0 0.20" rpy="0 0 0"/> <!-- TODO mount pose -->
  </joint>

  <!-- ============ Astra Pro camera ============
       camera_link is REP-103 aligned with base; pitch is on camera_depth/color_frame.
       TODO: mount x/z, and camera_pitch (rad) if tilted down. -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.03 0.16 0.03"/></geometry>
      <material name="blue"><color rgba="0.2 0.4 0.8 1"/></material>
    </visual>
  </link>
  <joint name="camera_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.18 0 0.25" rpy="0 0 0"/> <!-- TODO mount pose -->
  </joint>

  <!-- Mount frames carry the downward pitch (set rpy pitch here; 0 = level). -->
  <link name="camera_depth_frame"/>
  <joint name="camera_depth_frame_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/> <!-- TODO pitch: rpy="0 <pitch_rad> 0" -->
  </joint>
  <link name="camera_color_frame"/>
  <joint name="camera_color_frame_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_color_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/> <!-- TODO pitch -->
  </joint>

  <!-- Optical frames: REP-103 body -> optical (x-right, y-down, z-forward). Fixed. -->
  <link name="camera_depth_optical_frame"/>
  <joint name="camera_depth_optical_joint" type="fixed">
    <parent link="camera_depth_frame"/>
    <child link="camera_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>
  <link name="camera_color_optical_frame"/>
  <joint name="camera_color_optical_joint" type="fixed">
    <parent link="camera_color_frame"/>
    <child link="camera_color_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- ============ IMU (GY-9250 / MPU9250, 9-axis) ============
       ESP32 publishes sensor_msgs/Imu on /imu/data_raw (accel+gyro) and, if mag
       is used, sensor_msgs/MagneticField on /imu/mag (AK8963), stamped frame_id
       "imu_link". Mount rigidly near base; this frame's axes must match the chip
       placement (REP-145: +X forward, +Y left, +Z up). TODO: mount pose + axis rpy. -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/> <!-- TODO mount pose + axis alignment -->
  </joint>

  <!-- ============ VL53L1X ToF x3 ============
       Each publishes sensor_msgs/Range (from ESP32) on /tof_front|left|right,
       stamped with the matching frame_id. Used later in Nav2 RangeSensorLayer to
       cover the lidar's blind spots (low obstacles / cliffs).
       TODO: set real mount poses. If used as DOWNWARD cliff sensors, pitch them
       down (rpy pitch ~ +1.57 looks at floor). Default below = forward-facing. -->
  <link name="tof_front_link"/>
  <joint name="tof_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="tof_front_link"/>
    <origin xyz="0.20 0.0 0.08" rpy="0 0 0"/> <!-- TODO -->
  </joint>
  <link name="tof_left_link"/>
  <joint name="tof_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="tof_left_link"/>
    <origin xyz="0.18 0.12 0.08" rpy="0 0 0.6"/> <!-- TODO -->
  </joint>
  <link name="tof_right_link"/>
  <joint name="tof_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="tof_right_link"/>
    <origin xyz="0.18 -0.12 0.08" rpy="0 0 -0.6"/> <!-- TODO -->
  </joint>
</robot>
