<?xml version="1.0"?>
<!-- Robot frame (REP-103):
     Origin: ground point midway between wheel centers (base_footprint / base_link).
     +X forward, +Y left, +Z up.
     Camera: 5 cm behind wheel center, 37 cm above ground, pitched 17 deg down from horizontal toward +X. -->
<robot name="deck_robot">
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="-0.05 0 0.12" rpy="0 0 0"/>
      <geometry>
        <box size="0.35 0.30 0.04"/>
      </geometry>
      <material name="deck_gray">
        <color rgba="0.55 0.55 0.55 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.05 0 0.12" rpy="0 0 0"/>
      <geometry>
        <box size="0.35 0.30 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.05 0 0.12" rpy="0 0 0"/>
      <mass value="8.0"/>
      <inertia ixx="0.08" ixy="0" ixz="0" iyy="0.08" iyz="0" izz="0.12"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.0323" length="0.02"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
  </link>

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.0323" length="0.02"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
  </link>

  <!-- Wheel centers: y=±half_track, z=wheel radius above ground origin. -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.104 0.0323" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.104 0.0323" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.03"/>
      </geometry>
      <material name="camera_blue">
        <color rgba="0.2 0.4 0.8 1"/>
      </material>
    </visual>
  </link>

  <!-- (-0.05, 0, 0.37) m = 5 cm rear, 37 cm high.
       camera_link stays REP-103 aligned with base; mount pitch is on depth/color static TF. -->
  <joint name="camera_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="-0.05 0 0.37" rpy="0 0 0"/>
  </joint>
</robot>
